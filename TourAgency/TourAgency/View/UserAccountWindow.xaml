<Window x:Class="TourAgency.View.UserAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Мій Аккаунт" Height="680" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F1F8E9">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="12" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Margin" Value="0,2,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="Transparent" 
                                BorderBrush="#A5D6A7" 
                                BorderThickness="1.5" 
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E8F5E9"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#2E7D32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="White" Margin="25" CornerRadius="25">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.1" Color="#1B5E20"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20" VerticalAlignment="Top">

                    <StackPanel Visibility="{Binding IsNotLoggedIn, Converter={StaticResource BoolToVis}}" Margin="0,50,0,0">
                        <TextBlock Text="🌍" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="ПОЧНІТЬ СВОЮ ПОДОРОЖ" 
                                   FontSize="16" FontWeight="Bold" Foreground="#2E7D32"
                                   TextAlignment="Center" Margin="0,0,0,30"/>

                        <Button Content="Увійти" 
                                Command="{Binding OpenLoginCommand}"
                                Style="{StaticResource ModernButtonStyle}"
                                Height="45" Width="220" Margin="0,0,0,12"
                                Background="#4CAF50"/>

                        <Button Content="Створити аккаунт" 
                                Command="{Binding RegisterCommand}"
                                Style="{StaticResource ModernButtonStyle}"
                                Height="45" Width="220"
                                Background="#81C784"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">

                        <Border Width="80" Height="80" CornerRadius="40" Background="#C8E6C9" Margin="0,10,0,10">
                            <TextBlock Text="👤" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Вітаємо," FontSize="14" Foreground="#66BB6A" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding UserName}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#1B5E20"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <StackPanel Visibility="{Binding ShowProfileWarning, Converter={StaticResource BoolToVis}}" Margin="0,0,0,20">
                            <Border Background="#FFF3E0" CornerRadius="15" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="✈️ Майже готово!" FontWeight="Bold" Foreground="#E65100" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Додайте паспортні дані, щоб бронювати тури." 
                       FontSize="12" Foreground="#EF6C00" TextAlignment="Center" TextWrapping="Wrap" Margin="0,5"/>
                                    <Button Content="Заповнити профіль" 
                    Command="{Binding OpenCompleteProfileCommand}"
                    Style="{StaticResource ModernButtonStyle}"
                    Background="#FF9800" Height="40" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsProfileFilled, Converter={StaticResource BoolToVis}}">
                            <Grid Margin="0,10,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" 
                                        Command="{Binding OpenFullInfoCommand}"
                                        Background="#81C784" 
                                        Height="70" 
                                        Style="{StaticResource ModernButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="📄" FontSize="20" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Повна інфо" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="2" 
                                        Command="{Binding OpenMyToursCommand}"
                                        Background="#4CAF50" 
                                        Height="70" 
                                        Style="{StaticResource ModernButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="🌍" FontSize="20" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Мої тури" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <Button Content="Вийти з профілю" 
                                Command="{Binding LogoutCommand}"
                                Style="{StaticResource ModernButtonStyle}"
                                Height="45" Width="220"
                                Background="#EF5350" Margin="0,10,0,0"/>
                    </StackPanel>

                    <Button Content="Закрити" 
                            Command="{Binding CloseCommand}" 
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource CloseButtonStyle}"
                            Height="35" Width="110" Margin="0,30,0,10"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>