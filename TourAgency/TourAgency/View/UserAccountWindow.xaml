<Window x:Class="TourAgency.View.UserAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Мій Аккаунт" Height="640" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F1F8E9">
    <Window.Resources>
        <!-- Конвертер для перемикання видимості панелей -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Загальний стиль для кнопок -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="12" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Margin" Value="0,2,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки закриття (контурна) -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="Transparent" 
                                BorderBrush="#A5D6A7" 
                                BorderThickness="1.5" 
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E8F5E9"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#2E7D32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="White" Margin="25" CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1" Color="#1B5E20"/>
            </Border.Effect>

            <Grid Margin="20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                    <!-- Секція для неавторизованого користувача (Гість) -->
                    <StackPanel Visibility="{Binding IsNotLoggedIn, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="🌍" FontSize="45" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <TextBlock Text="ПОЧНІТЬ СВОЮ ПОДОРОЖ" 
                                   FontSize="16" FontWeight="Bold" Foreground="#2E7D32"
                                   TextAlignment="Center" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" Margin="0,0,0,25"/>

                        <Button Content="Увійти" 
                                Command="{Binding OpenLoginCommand}"
                                Style="{StaticResource ModernButtonStyle}"
                                Height="45" Width="220" Margin="0,0,0,12"
                                Background="#4CAF50">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2" Color="#1B5E20"/>
                            </Button.Effect>
                        </Button>

                        <Button Content="Створити аккаунт" 
                                Command="{Binding RegisterCommand}"
                                Style="{StaticResource ModernButtonStyle}"
                                Height="45" Width="220"
                                Background="#81C784"/>
                    </StackPanel>
                    <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
                        <Border Width="70" Height="70" CornerRadius="35" Background="#C8E6C9" Margin="0,20,0,5" HorizontalAlignment="Center">
                            <TextBlock Text="👤" FontSize="35" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Раді вас бачити," FontSize="14" Foreground="#66BB6A" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding UserName}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#1B5E20"
                                   HorizontalAlignment="Center" Margin="0,0,0,25"/>

                        <Button Content="Вийти з профілю" 
                                Command="{Binding LogoutCommand}"
                                Style="{StaticResource ModernButtonStyle}"
                                Height="45" Width="220"
                                Background="#EF5350"/>
                    </StackPanel>

                    
                    <Button Content="Закрити" 
                            Command="{Binding CloseCommand}" 
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource CloseButtonStyle}"
                            Height="35" Width="110" Margin="0,30,0,0"/>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>