<Window x:Class="TourAgency.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:TourAgency.Helpers"
        Title="Вхід - Tour Agency" Height="450" Width="400" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F1F8E9">

    <Grid>
        <Border Width="320" VerticalAlignment="Center" Background="White" CornerRadius="20" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1" Color="#1B5E20"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Вхід у систему" FontSize="24" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                <TextBlock Text="Email:" Foreground="#555" Margin="5,0,0,5" FontSize="12" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TourInputStyle}" Margin="0,0,0,15"/>

                <TextBlock Text="Пароль:" Foreground="#555" Margin="5,0,0,5" FontSize="12" FontWeight="SemiBold"/>
                <PasswordBox Style="{StaticResource TourPasswordStyle}"
                             helpers:PasswordBoxHelper.BindPassword="True"
                             helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay}"/>

                <Button Content="Увійти" 
                        Command="{Binding LoginCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Background="#4CAF50" Foreground="White" Height="45" FontSize="16" FontWeight="Bold" Margin="0,20,0,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Ще не маєте акаунту? Реєстрація" 
                        Command="{Binding OpenRegisterCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="#2E7D32" 
                        Margin="0,15,0,0" Cursor="Hand" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>