<Window x:Class="TourAgency.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TourAgency"
        mc:Ignorable="d"
        Title="Tour Agency - Подорожуй з нами" Height="700" Width="1100" 
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize" MinHeight="600" MinWidth="900">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
            <!-- Темно-зелений текст -->
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DCEDC8"/>
              
                    <Setter Property="Foreground" Value="#1B5E20"/>
            
                </Trigger>
            </Style.Triggers>
        </Style>


        <Style x:Key="GenreCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#33691E"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            
                            <Grid Width="18" Height="18">
                                <Border x:Name="Box" 
                                CornerRadius="4" 
                                BorderBrush="#8BC34A" 
                                BorderThickness="2" 
                                Background="White"/>

                              
                                <Viewbox x:Name="CheckMarkViewbox" Margin="3" Visibility="Collapsed">
                                    <Path x:Name="CheckMark" 
                                  Data="M 0,5 L 3,8 L 10,0" 
                                  Stroke="White" 
                                  StrokeThickness="2" 
                                  StrokeStartLineCap="Round" 
                                  StrokeEndLineCap="Round" 
                                  StrokeLineJoin="Round"/>
                                </Viewbox>
                            </Grid>

                            <ContentPresenter Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#689F38"/>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#8BC34A"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#8BC34A"/>
                                <Setter TargetName="CheckMarkViewbox" Property="Visibility" Value="Visible"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="AccountButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F1F8E9"/>
            <Setter Property="BorderBrush" Value="#C5E1A5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="15" Padding="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="#33691E"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DCEDC8"/>
                    <Setter Property="BorderBrush" Value="#8BC34A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#FAFAFA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
   
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" BorderBrush="#EEEEEE" BorderThickness="0,0,1,0">
            <StackPanel Margin="15">
                <TextBlock Text="TOUR AGENCY" FontSize="20" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                <Button Style="{StaticResource MenuButtonStyle}" Content="🌍 Усі тури"/>
                <Button Style="{StaticResource MenuButtonStyle}" Content="🔥 Гарячі пропозиції"/>
                <Button Style="{StaticResource MenuButtonStyle}" Content="📜 Мої замовлення"/>

                <Separator Margin="0,15" Background="#E0E0E0"/>

                <TextBlock Text="Тип відпочинку" FontSize="12" FontWeight="Bold" Foreground="#9E9E9E" Margin="5,0,0,10"/>
                <CheckBox Style="{StaticResource GenreCheckBoxStyle}" Content="Пляжний"/>
                <CheckBox Style="{StaticResource GenreCheckBoxStyle}" Content="Гірськолижний"/>
                <CheckBox Style="{StaticResource GenreCheckBoxStyle}" Content="Екскурсійний"/>

                <Button Style="{StaticResource AccountButtonStyle}" Command="{Binding OpenAccountCommand}" Content="Профіль" Margin="0,30,0,0" VerticalAlignment="Bottom"/>
            </StackPanel>
        </Border>

        
        <Grid Grid.Column="1" Margin="20">
            <TextBlock Text="Оберіть свою наступну пригоду!" FontSize="24" Foreground="#333" FontWeight="Medium"/>
        </Grid>
    </Grid>
</Window>