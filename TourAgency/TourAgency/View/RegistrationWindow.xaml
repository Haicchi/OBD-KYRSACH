<Window x:Class="TourAgency.View.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:TourAgency.Helpers"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Реєстрація - Tour Agency" Height="620" Width="420" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F1F8E9">

    <Grid>
        <Border Width="360" VerticalAlignment="Center" Background="White" CornerRadius="20" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1" Color="#1B5E20"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Створити аккаунт" FontSize="24" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                <TextBlock Text="Ваше ПІБ (Прізвище Ім'я По батькові):" Foreground="#555" Margin="5,0,0,5" FontSize="11" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" 
         Style="{StaticResource ValidatedTextBoxStyle}">
                    <i:Interaction.Behaviors>
                        <helpers:LetterInputBehavior/>
                    </i:Interaction.Behaviors>
                </TextBox>

                <TextBlock Text="Електронна пошта:" Foreground="#555" Margin="5,0,0,5" FontSize="12" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                         Style="{StaticResource ValidatedTextBoxStyle}"/>

                <TextBlock Text="Номер телефону:" Foreground="#555" Margin="5,0,0,5" FontSize="12" FontWeight="SemiBold"/>
                <TextBox x:Name="PhoneTextBox"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         MaxLength="13"
                         Style="{StaticResource ValidatedTextBoxStyle}">
                    <i:Interaction.Behaviors>
                        <helpers:NumericInputBehavior AllowPlus="True"/>
                    </i:Interaction.Behaviors>
                </TextBox>

                <TextBlock Text="Пароль (мін. 6 символів):" Foreground="#555" Margin="5,0,0,5" FontSize="12" FontWeight="SemiBold"/>
                <PasswordBox x:Name="PasswordInput" 
                             Style="{StaticResource TourPasswordStyle}"
                             helpers:PasswordBoxHelper.BindPassword="True"
                             helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                <Button Content="Зареєструватися" 
                        Command="{Binding RegisterCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Background="#4CAF50" Foreground="White" Height="45" FontSize="16" FontWeight="Bold" Cursor="Hand" Margin="0,10,0,0"
                        Style="{StaticResource ModernButtonStyle}"></Button>

                <Button Content="Вже є аккаунт? Увійти" 
                        Command="{Binding OpenLoginCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Background="Transparent" BorderThickness="0" Foreground="#2E7D32" 
                        Margin="0,15,0,0" Cursor="Hand" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>