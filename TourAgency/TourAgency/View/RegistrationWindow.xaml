<Window x:Class="TourAgency.View.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:helpers="clr-namespace:TourAgency.Helpers"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TourAgency"
        mc:Ignorable="d"
        Title="Реєстрація - Tour Agency" Height="600" Width="420" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F1F8E9">

    <Window.Resources>
      
        <Style x:Key="TourInputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#A5D6A7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="8" Background="White" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4CAF50"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TourPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#A5D6A7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" CornerRadius="8" Background="White" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4CAF50"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Width="360" VerticalAlignment="Center" Background="White" CornerRadius="20" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1" Color="#1B5E20"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Створити аккаунт" FontSize="24" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                <TextBlock Text="Ваше ПІБ:" Foreground="#555" Margin="5,0,0,5" FontSize="12" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TourInputStyle}"/>

                <TextBlock Text="Електронна пошта:" Foreground="#555" Margin="5,0,0,5" FontSize="12" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TourInputStyle}"/>

                <TextBlock Text="Номер телефону:" Foreground="#555" Margin="5,0,0,5" FontSize="12" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TourInputStyle}"/>

                <TextBlock Text="Пароль:" Foreground="#555" Margin="5,0,0,5" FontSize="12" FontWeight="SemiBold"/>
                <!-- Використовуємо кастомний PasswordBoxHelper, як у твоєму прикладі -->
                <PasswordBox x:Name="PasswordInput" 
                             Style="{StaticResource TourPasswordStyle}"
                             helpers:PasswordBoxHelper.BindPassword="True"
                             helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Зареєструватися" 
                        Command="{Binding RegisterCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Background="#4CAF50" Foreground="White" Height="45" FontSize="16" FontWeight="Bold" Cursor="Hand" Margin="0,10,0,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Вже є аккаунт? Увійти" 
                        Command="{Binding OpenLoginCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="#2E7D32" 
                        Margin="0,15,0,0" Cursor="Hand" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>