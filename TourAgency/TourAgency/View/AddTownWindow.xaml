<Window x:Class="TourAgency.View.AddTownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати місто" Height="280" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F1F8E9">
    <Grid>
        <Border Background="White" Margin="15" CornerRadius="10">
            <StackPanel Margin="15">
                <TextBlock Text="НОВЕ МІСТО" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="Оберіть країну:" Margin="0,0,0,5" Foreground="#555"/>
                <ComboBox ItemsSource="{Binding AllCountries}" SelectedItem="{Binding SelectedCountry}" DisplayMemberPath="Name" Height="30" Margin="0,0,0,10"/>

                <TextBlock Text="Назва міста:" Margin="0,0,0,5" Foreground="#555"/>
                <TextBox Text="{Binding NameInput, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center"/>

                <UniformGrid Columns="2" Margin="0,20,0,0">
                    <Button Content="ЗБЕРЕГТИ" Command="{Binding ConfirmCommand}" CommandParameter="Town" 
                            Height="35" Background="#4CAF50" Foreground="White" Margin="0,0,5,0"/>
                    <Button Content="СКАСУВАТИ" Command="{Binding CloseCommand}" 
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Height="35" Background="#EF5350" Foreground="White" Margin="5,0,0,0"/>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</Window>